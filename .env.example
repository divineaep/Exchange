# ─────────────────────────────────────────────
#  FastExchanger — Environment Configuration
# ─────────────────────────────────────────────

# Discord Bot Token
BOT_TOKEN=your_bot_token_here

# Discord Application / Client ID
CLIENT_ID=your_client_id_here

# Guild ID (your server)
GUILD_ID=your_guild_id_here

# Bot Owner Discord ID
BOT_OWNER=your_discord_id_here

# Comma-separated Exchanger Discord IDs
EXCHANGERS=id1,id2,id3

# Comma-separated Admin Discord IDs
ADMINS=id1,id2

# ─── Channel IDs ──────────────────────────────

# Where the main exchange panel is posted
PANEL_CHANNEL_ID=

# Category for ticket channels
TICKET_CATEGORY_ID=

# Log channels
LOG_EXCHANGE=
LOG_VOUCHES=
LOG_SCAM=
LOG_STAFF=

# Vouch channel (public)
VOUCH_CHANNEL_ID=

# ─── Security ─────────────────────────────────

# Minimum account age in days to create a ticket
MIN_ACCOUNT_AGE_DAYS=7

# Minimum server membership age in days
MIN_JOIN_AGE_DAYS=1

# ─── Express Dashboard ─────────────────────────
DASHBOARD_PORT=3000
DASHBOARD_SECRET=change_this_secret
